const goCommand = (rest, player, game) => {
    player.write(`Rooms length = ${JSON.stringify(Object.keys(game.rooms))}`)
    const destination = game.rooms[Math.floor(game.rooms.length * Math.random())];
    player.setCurrentRoom(destination);
};
command('random', goCommand)
