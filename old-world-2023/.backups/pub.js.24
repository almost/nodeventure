item("Remi", {
  description: "A short man with a cigarette in his mouth and a Pravha in his hand."
});

let remiCount = 0;

const pokeRemi = function () {
  remiCount += 1;
  
  item(`Remi ${remiCount}`, {
    description: "Another short man with a cigarette in his mouth and a Pravha in his hand."
  });
  
  for (let i = 0; i < remiCount; i += 1) {
    itemCommand("poke", `Remi ${i + 1}`, "You should never poke Remi after midnight", pokeRemi);
  }
}

itemCommand("poke", "Remi", "You should never poke Remi after midnight", pokeRemi);
});