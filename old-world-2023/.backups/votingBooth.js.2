room("votingBooth", {
  description: "It's time to vote! Vote! Vote! Vote!",
  exits: {
    south: "olly",
    east: "olly",
  }
});


command('vote', 'Use your democratic vote to vote the bastards out', (rest, player, game) => {
    if (player.getCurrentRoom() == "votingBooth") {
        player.info("You're vote had precisely the effect you thought it would")
    } else {
        player.warn("You can't use your vote today")
    }
})