room("home", {
  description: "You are in the lobby of Spaces in Brighton. Tonight is Async night and we're building a game!",
  exits: {
    south: "home2",
  }
});

room("home2", {
  description: "You are in the southern part of the lobby of Spaces in Brighton, there are some booths here for meetings.",
  exits: {
    north: "home",
  }
});

const towncrier = character("towncrier", {
    location: "home",
    description: "The town crier looks like nothing like a town and isn't crying."
})

handler("tick", () => {
   // A tick happens once a second, but we only want to do something every 30 seconds or so
   if (Math.random() < 0.03) {
       const room = towncrier.getCurrentRoom();
       room.broadcast("Hear yee hear yee! This game neeed some more things added to it!");
   }
});